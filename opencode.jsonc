{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "agente-personal": {
      "description": "Tu agente personal con conexion al movil via Telegram, noticias reales multi-fuente, IA local, y generacion de imagenes.",
      "mode": "subagent"
    }
