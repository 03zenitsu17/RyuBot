      "type": "local",
      "command": ["python", "servers/telegram_mcp.py"],
      "enabled": true,
      "env": {
        "TELEGRAM_BOT_TOKEN": "8860896177:AAH8KVwId2oGPWnqzLMHz-ay0BaXu1jbjiY"
      }
    }
  }
}
